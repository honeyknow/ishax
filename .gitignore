# =============================================================
# ISHA-X EDR — .gitignore
# =============================================================

# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
venv/
.venv/

# SQLite databases — ephemeral data, never commit
*.db
*.db-shm
*.db-wal
*.sqlite3

# Node / React
node_modules/
dist/
dist-ssr/
*.local

# Secrets — NEVER commit these
.env
server/backend/.env
*.key
*.pem

# Log files
*.log
ingestor.log
backend.log
frontend.log

# Inno Setup outputs
endpoint/Output/
endpoint/Output/*.exe
endpoint/tailscale-setup.exe

# Large binary assets (not needed in git)
endpoint.zip
*.msi
Sysmon64.exe
amsi_watcher.exe

# Temp installer build dirs
ishax_build_*/

# Garbage / legacy / scratch
garbage/
legacy/
recovery/
lol.docx
lol_original.docx
lol.md
evidence_t1059_001.txt
t1059_001_report_data.json
vm_commands.txt
query
codespace_trigger/
IMPLEMENTATION_PLAN.md
project.md
master_technical_report.md

# Vite
.vite/
