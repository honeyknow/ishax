# =============================================================
# ISHA-X EDR — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# -----------------------------------------------------------
# Google OAuth 2.0  (get from Google Cloud Console)
# -----------------------------------------------------------
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# -----------------------------------------------------------
# Session Security  (generate with: python -c "import secrets; print(secrets.token_hex(32))")
# -----------------------------------------------------------
SESSION_SECRET=change-me-to-a-random-hex-string

# -----------------------------------------------------------
# Access Control
# Comma-separated list of allowed Google emails (admin email must be first)
# -----------------------------------------------------------
ALLOWED_EMAILS=info.honeyknows@gmail.com,user2@gmail.com,user3@gmail.com

# -----------------------------------------------------------
# Tailscale  (get Auth Key from login.tailscale.com/admin/settings/keys)
# -----------------------------------------------------------
TAILSCALE_AUTH_KEY=tskey-auth-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------
# Server Hostname  (Cloudflare CNAME → Tailscale MagicDNS hostname)
# -----------------------------------------------------------
SERVER_HOST=agents.weknows.me

# -----------------------------------------------------------
# Wazuh Manager API  (running inside your Codespace)
# -----------------------------------------------------------
WAZUH_API_BASE=https://localhost:55000
WAZUH_API_USER=wazuh
WAZUH_API_PASS=your-wazuh-api-password

# -----------------------------------------------------------
# Inno Setup Compiler  (only needed if running on Windows)
# On Linux/Codespace, iscc.exe is not available (no installer compilation)
# -----------------------------------------------------------
ISCC_PATH=C:\Program Files (x86)\Inno Setup 6\iscc.exe

# -----------------------------------------------------------
# Frontend CORS origin  (dashboard URL in production)
# -----------------------------------------------------------
FRONTEND_ORIGIN=https://weknows.me

# -----------------------------------------------------------
# Ingestor settings
# -----------------------------------------------------------
MULTI_TENANT=1
ARCHIVES_JSON=/var/ossec/logs/archives/archives.json
EDR_DB_PATH=/workspaces/latestedr/server/pipeline/edr.db
POLL_INTERVAL=0.5
EDR_RETENTION_DAYS=30
